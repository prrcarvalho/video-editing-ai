# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Local environment and credentials
.env
.env.*
!.env.example
!.env.*.example
.gemini_cookies.env
.gemini_pipeline_chrome/
cookies.json
*_cookies.json
*.pem
*.key

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node/TypeScript dependencies and build output
node_modules/
dist/
build/
.next/
.nuxt/
.turbo/
.parcel-cache/
.eslintcache
*.tsbuildinfo

# Python caches and local virtualenvs
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.coverage
htmlcov/

# Local package/tool caches
.cache/
.npm/
.pnpm-store/
.uv-cache/
/.opensrc/

# Local agent runtime state; keep checked-in skills/workflows visible
.claude/*.lock
.claude/settings.local.json
.agents/settings.local.json

# Gemini/web automation local auth caches, if created in-repo
gemini_webapi/
.cached_cookies_*.json

# HyperFrames generated previews, render output, and media analysis caches
hyperframes-reels/**/.thumbnails/
hyperframes-reels/**/.waveform-cache/
hyperframes-reels/**/renders/

# Temporary working files
tmp/
temp/
*.tmp
